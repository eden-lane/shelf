{
  "name": "@bookmarks/extensions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:safari": "bun run build:safari:web && bun scripts/build-safari-project.mjs",
