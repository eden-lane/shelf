---
import "../styles/global.css";
import Main from "../layouts/main.astro";
---

<style>
    article {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    
    .heading {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        gap: 8px;
        align-items: center;
    }

    h1 {
        margin: 0;
        padding: 0;
    }

    .slogan {
        font-size: 1.25rem;
        font-weight: 400;
        grid-column: 2;
    }

    .screenshot {
        height: 400px;
        aspect-ratio: 16 / 9;
        background-color: #eee;
    }
</style>

<Main>
    <article>
    <div class="heading">
        <img src="/shelf-icon.png" alt="Shelf Logo" width="48" height="48" />
        <h1>Shelf</h1>
        <span class="slogan">A new home for your bookmarks</span>
    </div>

    <div class="screenshot"></div>
    </article>

</Main>

